# ---------------------------------------------------------------------------
# CapNomade — environment variables
# Copy to `.env.local` (dev) or set in your hosting provider (prod).
# Never commit real secrets.
# ---------------------------------------------------------------------------

# --- App ---------------------------------------------------------------------
# Canonical public URL of the deployed app. Used for OG tags, sitemap, auth.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=CapNomade

# --- Supabase ----------------------------------------------------------------
# From your Supabase project → Settings → API.
# `anon` is safe to expose to the browser. `service_role` MUST stay server-only.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
SUPABASE_SERVICE_ROLE_KEY=ey...

# --- Map tiles (production-ready vector basemap) -----------------------------
# Configure your own MapLibre style endpoint and/or tile key.
# Examples: MapTiler, Stadia, Protomaps. URL templates may contain {key}.
NEXT_PUBLIC_MAPLIBRE_STYLE_URL=https://api.maptiler.com/maps/streets-v2/style.json?key={key}
NEXT_PUBLIC_MAP_TILES_API_KEY=your-public-map-tiles-key
# Dark-mode style (optional)
NEXT_PUBLIC_MAPLIBRE_STYLE_URL_DARK=https://api.maptiler.com/maps/streets-v2-dark/style.json?key={key}

# --- Google Maps Platform (server-only) --------------------------------------
# Used for geocoding + Routes / Route Matrix from server actions only.
# DO NOT expose to client. Restrict the key to the relevant APIs in GCP.
GOOGLE_MAPS_SERVER_API_KEY=AIza...

# --- Resend (transactional email) --------------------------------------------
RESEND_API_KEY=re_...
EMAIL_FROM="CapNomade <hello@capnomade.app>"
EMAIL_REPLY_TO=support@capnomade.app

# --- AI insights provider (optional) -----------------------------------------
# If not set, insights fall back to a static disabled state with a notice.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
INSIGHTS_PROVIDER=disabled  # disabled | openai | anthropic

# --- Carbon emission factors -------------------------------------------------
# Defaults follow ADEME-style emission factors (kgCO2e per km).
CARBON_FACTOR_PLANE_SHORT_KM=0.255
CARBON_FACTOR_PLANE_MEDIUM_KM=0.187
CARBON_FACTOR_PLANE_LONG_KM=0.152
CARBON_FACTOR_CAR_KM=0.193
CARBON_FACTOR_TRAIN_KM=0.027
CARBON_FACTOR_BUS_KM=0.103
CARBON_FACTOR_FERRY_KM=0.115

# --- Security / auth ---------------------------------------------------------
# Optional invite token signing secret (must be >= 32 chars).
INVITE_TOKEN_SECRET=change-me-to-a-32-plus-character-secret
